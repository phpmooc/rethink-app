<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_rethink_plus"
    app:startDestination="@id/rethinkPlus">

    <fragment
        android:id="@+id/rethinkPlus"
        android:name="com.celzero.bravedns.ui.fragment.RethinkPlusFragment"
        android:label="Rethink Plus" >
        <!--
          Navigate forward to the dashboard.
          popUpTo rethinkPlus (inclusive=false) keeps rethinkPlus in the back stack so that
          pressing Back from the dashboard returns to the purchase screen, not home.
        -->
        <action
            android:id="@+id/action_switch_to_rethinkPlusDashboardFragment"
            app:destination="@id/rethinkPlusDashboardFragment"
            app:popUpTo="@id/rethinkPlus"
            app:popUpToInclusive="false" />
    </fragment>

   <fragment
        android:id="@+id/rethinkPlusDashboardFragment"
        android:name="com.celzero.bravedns.ui.fragment.RethinkPlusDashboardFragment"
        android:label="Help &amp; Support" >
        <!--
          Navigate back to the purchase/subscribe screen.
          Used by renewButton and the no-subscription guard in onViewCreated.
          popUpTo rethinkPlus inclusive=true so we replace it cleanly rather than stacking.
        -->
        <action
            android:id="@+id/action_rethinkPlusDashboard_to_rethinkPlus"
            app:destination="@id/rethinkPlus"
            app:popUpTo="@id/rethinkPlus"
            app:popUpToInclusive="true" />
    </fragment>
</navigation>
