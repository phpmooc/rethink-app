<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="12dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:minHeight="56dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_city_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="?attr/primaryTextColor"
            android:fontFamily="sans-serif-medium"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="New York" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_server_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?attr/secondaryTextColor"
            android:alpha="0.5"
            android:layout_marginTop="2dp"
            android:visibility="gone"
            tools:visibility="visible"
            tools:text="3 servers" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="12dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_load"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?attr/primaryLightColorText"
            android:fontFamily="sans-serif-medium"
            android:layout_marginEnd="8dp"
            android:visibility="gone"
            tools:visibility="visible"
            tools:text="45%" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_link_speed"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:textSize="11sp"
            android:textColor="?attr/homeScreenHeaderTextColor"
            android:layout_marginEnd="12dp"
            android:visibility="gone"
            app:chipBackgroundColor="?attr/chipColorBgNormal"
            app:chipStrokeWidth="0dp"
            app:chipMinHeight="24dp"
            app:chipStartPadding="8dp"
            app:chipEndPadding="8dp"
            app:chipIconEnabled="false"
            app:closeIconEnabled="false"
            app:ensureMinTouchTargetSize="false"
            tools:visibility="visible"
            tools:text="1.2 Gbps" />

        <androidx.appcompat.widget.AppCompatCheckBox
            android:id="@+id/checkbox_server"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:buttonTint="?attr/accentGood"
            android:clickable="false"
            android:focusable="false" />

    </LinearLayout>

</LinearLayout>
